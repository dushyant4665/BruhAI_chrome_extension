{
    "openapi": "3.0.0",
    "info": {
      "title": "AI Assistant API",
      "version": "1.0.0"
    },
    "paths": {
      "/api/v1/process": {
        "post": {
          "summary": "Process text with AI",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "prompt": { "type": "string" },
                    "model": { 
                      "type": "string",
                      "enum": ["gemini", "openai"]
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Successful response",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/AIResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "AIResponse": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "text": { "type": "string" },
            "model": { "type": "string" },
            "tokens": { "type": "number" }
          }
        }
      }
    }
  }

{
  "manifest_version": 3,
  "name": "AI Code Assistant",
  "version": "1.0",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "permissions": ["activeTab", "contextMenus", "storage"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ]
}